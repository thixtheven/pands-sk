import pandas as pd# pandas используем для работы с датафреймом
from sklearn.model_selection import train_test_split# функция для разделения данных на обучающую и тестовую выборки
from sklearn.linear_model import LogisticRegression# Модель логистической регрессии для задачи классификации
from sklearn.metrics import accuracy_score# Метрика для оценки качества модели

# создаем словарь с данными о клиентах
data = {
    "age": [18, 22, 25, 30, 35, 40, 45, 50],
    # Доход клиента
    "income": [25000, 30000, 35000, 50000, 60000, 70000, 80000, 90000],
    
    "buy": [0, 0, 0, 1, 1, 1, 1, 1]# 0 - не купил, 1 - купил
}

df = pd.DataFrame(data)# из словаря делаем таблицу



# подготовка данных
# выбираем признаки, на которых будет обучаться модель
X = df[["age", "income"]]

# выбираем целевую переменную,
# которую модель должна научиться предсказывать
y = df["buy"]
# разделим данные:
# 75% - обучение модели
# 25% - проверка качества модели
X_train, X_test, y_train, y_test = train_test_split(
    X,
    y,
    test_size=0.25,
    random_state=42
)

model = LogisticRegression()# создаем модель

model.fit(X_train, y_train)#передаем модели данные чтобы она нашла закономерность между признаками и ответами


predictions = model.predict(X_test)# просим модель предсказать ответы для тестовой выборки

accuracy = accuracy_score(y_test, predictions)#сравниваем правильные ответы с ответами модели


print("Точность модели:", accuracy)# выводим точность модели
